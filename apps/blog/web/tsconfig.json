{
  "extends": "../../../packages/typescript-config/nextjs.json",
  "compilerOptions": {
    "moduleResolution": "Bundler",
    "paths": {
      "#site/content": ["./.velite"],
      "@/*": ["./src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    "next-env.d.ts",
    "next.config.ts",
    ".next/types/**/*.ts",
    ".velite"
  ],

  "exclude": ["node_modules", "velite.config.ts"]
}
